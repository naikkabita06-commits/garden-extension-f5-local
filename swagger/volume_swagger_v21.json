{
  "swagger": "2.0",
  "info": {
    "title": "Volume API",
    "description": "REST API for managing Volumes, Volume Snapshots, Volume Attachments, Volume Types, Filesystem Formats, and Labels.",
    "version": "2.1"
  },
  "basePath": "/api/v2.1",
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Bearer token. Example: 'Bearer <token>'"
    }
  },
  "security": [{ "Bearer": [] }],
  "tags": [
    { "name": "Volumes", "description": "Volume CRUD and resize operations" },
    { "name": "Volume Snapshots", "description": "Snapshot lifecycle management" },
    { "name": "Volume Attachment", "description": "Attach and detach volumes to compute instances" },
    { "name": "Volume Types", "description": "Available volume types and filesystem formats" },
    { "name": "Labels", "description": "Label management for volumes and snapshots" }
  ],
  "paths": {
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/": {
      "get": {
        "tags": ["Volumes"],
        "summary": "List Volumes",
        "description": "Returns a paginated list of volumes for the project.",
        "operationId": "listVolumes",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" },
          { "$ref": "#/parameters/sort_desc" },
          {
            "name": "search",
            "in": "query",
            "type": "string",
            "description": "Search by volume name"
          },
          {
            "name": "include_bootable",
            "in": "query",
            "type": "boolean",
            "default": false,
            "description": "Include bootable (OS) volumes"
          },
          {
            "name": "compute_id",
            "in": "query",
            "type": "string",
            "description": "Filter to volumes attached to this compute UUID"
          },
          {
            "name": "az_name",
            "in": "query",
            "type": "string",
            "description": "Filter by availability zone name"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of volumes",
            "schema": { "$ref": "#/definitions/PaginatedVolumes" }
          },
          "401": { "$ref": "#/responses/Unauthorized" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/create-and-attach/": {
      "post": {
        "tags": ["Volumes"],
        "summary": "Create Volume (and optionally attach)",
        "description": "Creates a new volume and optionally attaches it to a compute instance in one operation.",
        "operationId": "createAndAttachVolume",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/VolumeCreateAndAttach" }
          }
        ],
        "responses": {
          "202": {
            "description": "Volume creation accepted",
            "schema": { "$ref": "#/definitions/VolumeResponse" }
          },
          "400": { "$ref": "#/responses/BadRequest" },
          "409": { "$ref": "#/responses/Conflict" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/{volume_uuid}/": {
      "get": {
        "tags": ["Volumes"],
        "summary": "Get Volume by UUID",
        "description": "Returns details of a specific volume.",
        "operationId": "getVolumeById",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" }
        ],
        "responses": {
          "200": {
            "description": "Volume details",
            "schema": { "$ref": "#/definitions/VolumeResponse" }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Volumes"],
        "summary": "Extend (Resize) Volume",
        "description": "Increases the size of a volume. Size can only be increased, never decreased.",
        "operationId": "extendVolume",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/VolumeExtend" }
          }
        ],
        "responses": {
          "202": {
            "description": "Volume resize accepted",
            "schema": { "$ref": "#/definitions/VolumeResponse" }
          },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Volumes"],
        "summary": "Delete Volume",
        "description": "Deletes a volume. Bootable (OS) volumes cannot be deleted.",
        "operationId": "deleteVolume",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" }
        ],
        "responses": {
          "202": { "description": "Volume deletion accepted" },
          "404": { "$ref": "#/responses/NotFound" },
          "409": { "$ref": "#/responses/Conflict" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/volume-snapshots/": {
      "get": {
        "tags": ["Volume Snapshots"],
        "summary": "List All Snapshots (Project)",
        "description": "Returns a paginated list of all volume snapshots for the project.",
        "operationId": "listProjectSnapshots",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" },
          { "$ref": "#/parameters/sort_desc" },
          {
            "name": "search",
            "in": "query",
            "type": "string",
            "description": "Search by snapshot name"
          },
          {
            "name": "az_name",
            "in": "query",
            "type": "string",
            "description": "Filter by availability zone name"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of snapshots",
            "schema": { "$ref": "#/definitions/PaginatedSnapshots" }
          },
          "401": { "$ref": "#/responses/Unauthorized" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/{volume_uuid}/snapshots/": {
      "get": {
        "tags": ["Volume Snapshots"],
        "summary": "List Snapshots for a Volume",
        "description": "Returns a paginated list of snapshots for the specified volume.",
        "operationId": "listVolumeSnapshots",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" },
          { "$ref": "#/parameters/sort_desc" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of snapshots",
            "schema": { "$ref": "#/definitions/PaginatedSnapshots" }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Volume Snapshots"],
        "summary": "Create Snapshot",
        "description": "Creates a new snapshot of the specified volume.",
        "operationId": "createSnapshot",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/SnapshotCreate" }
          }
        ],
        "responses": {
          "202": {
            "description": "Snapshot creation accepted",
            "schema": { "$ref": "#/definitions/SnapshotResponse" }
          },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/snapshots/{snapshot_uuid}/": {
      "get": {
        "tags": ["Volume Snapshots"],
        "summary": "Get Snapshot by UUID",
        "description": "Returns details of a specific snapshot.",
        "operationId": "getSnapshotById",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/snapshot_uuid" }
        ],
        "responses": {
          "200": {
            "description": "Snapshot details",
            "schema": { "$ref": "#/definitions/SnapshotResponse" }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Volume Snapshots"],
        "summary": "Delete Snapshot",
        "description": "Deletes a volume snapshot.",
        "operationId": "deleteSnapshot",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/snapshot_uuid" }
        ],
        "responses": {
          "202": { "description": "Snapshot deletion accepted" },
          "404": { "$ref": "#/responses/NotFound" },
          "409": { "$ref": "#/responses/Conflict" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/volume_attach/{volume_uuid}/": {
      "post": {
        "tags": ["Volume Attachment"],
        "summary": "Attach Volume to Compute",
        "description": "Attaches an existing volume to a compute instance.",
        "operationId": "attachVolume",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/VolumeAttach" }
          }
        ],
        "responses": {
          "202": {
            "description": "Attachment accepted",
            "schema": { "$ref": "#/definitions/VolumeResponse" }
          },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" },
          "409": { "$ref": "#/responses/Conflict" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/{volume_uuid}/volume_detach/": {
      "post": {
        "tags": ["Volume Attachment"],
        "summary": "Detach Volume from Compute",
        "description": "Detaches a volume from the specified compute instance.",
        "operationId": "detachVolume",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/VolumeDetach" }
          }
        ],
        "responses": {
          "202": { "description": "Detachment accepted" },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/{volume_uuid}/attached_devices/": {
      "get": {
        "tags": ["Volume Attachment"],
        "summary": "List Attached Compute Instances",
        "description": "Lists all compute instances to which this volume is currently attached.",
        "operationId": "listAttachedDevices",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/volume_uuid" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" },
          { "$ref": "#/parameters/sort_desc" }
        ],
        "responses": {
          "200": {
            "description": "List of attached compute instances",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/AttachedDevice" }
                },
                "total": { "type": "integer" }
              }
            }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/attachable-volumes": {
      "get": {
        "tags": ["Volume Attachment"],
        "summary": "List Attachable Volumes",
        "description": "Lists volumes in the project that are available to be attached to a compute instance.",
        "operationId": "listAttachableVolumes",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" },
          { "$ref": "#/parameters/sort_desc" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of attachable volumes",
            "schema": { "$ref": "#/definitions/PaginatedVolumes" }
          },
          "401": { "$ref": "#/responses/Unauthorized" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/volume_types": {
      "get": {
        "tags": ["Volume Types"],
        "summary": "List Volume Types",
        "description": "Returns all available volume types for the project.",
        "operationId": "listVolumeTypes",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" }
        ],
        "responses": {
          "200": {
            "description": "List of volume types",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/VolumeType" }
                },
                "total": { "type": "integer" }
              }
            }
          },
          "401": { "$ref": "#/responses/Unauthorized" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/filesystem_formats": {
      "get": {
        "tags": ["Volume Types"],
        "summary": "List Filesystem Formats",
        "description": "Returns all available filesystem formats that can be applied to a volume.",
        "operationId": "listFilesystemFormats",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" }
        ],
        "responses": {
          "200": {
            "description": "List of filesystem formats",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/FilesystemFormat" }
                },
                "total": { "type": "integer" }
              }
            }
          },
          "401": { "$ref": "#/responses/Unauthorized" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/labels": {
      "patch": {
        "tags": ["Labels"],
        "summary": "Add / Update Labels on a Volume",
        "description": "Adds or updates labels on the specified volume.",
        "operationId": "patchVolumeLabels",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/LabelPatch" }
          }
        ],
        "responses": {
          "200": { "description": "Labels updated successfully" },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/labels/{label_name}": {
      "get": {
        "tags": ["Labels"],
        "summary": "Get Volumes by Label",
        "description": "Returns all volumes that have the specified label.",
        "operationId": "getVolumesByLabel",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/label_name" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of volumes matching the label",
            "schema": { "$ref": "#/definitions/PaginatedVolumes" }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/snapshot/labels": {
      "patch": {
        "tags": ["Labels"],
        "summary": "Add / Update Labels on a Snapshot",
        "description": "Adds or updates labels on the specified volume snapshot.",
        "operationId": "patchSnapshotLabels",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/LabelPatch" }
          }
        ],
        "responses": {
          "200": { "description": "Labels updated successfully" },
          "400": { "$ref": "#/responses/BadRequest" },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    },
    "/volumes/domain/{organization_id}/project/{project_id}/volumes/snapshots/labels/{label_name}": {
      "get": {
        "tags": ["Labels"],
        "summary": "Get Snapshots by Label",
        "description": "Returns all volume snapshots that have the specified label.",
        "operationId": "getSnapshotsByLabel",
        "parameters": [
          { "$ref": "#/parameters/organization_id" },
          { "$ref": "#/parameters/project_id" },
          { "$ref": "#/parameters/label_name" },
          { "$ref": "#/parameters/limit" },
          { "$ref": "#/parameters/offset" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of snapshots matching the label",
            "schema": { "$ref": "#/definitions/PaginatedSnapshots" }
          },
          "404": { "$ref": "#/responses/NotFound" }
        }
      }
    }
  },
  "parameters": {
    "organization_id": {
      "name": "organization_id",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Organisation name (used in URL path)"
    },
    "project_id": {
      "name": "project_id",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Project name (used in URL path)"
    },
    "volume_uuid": {
      "name": "volume_uuid",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Volume UUID"
    },
    "snapshot_uuid": {
      "name": "snapshot_uuid",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Volume snapshot UUID"
    },
    "label_name": {
      "name": "label_name",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Label key or key:value to filter by (e.g. env or env:production)"
    },
    "limit": {
      "name": "limit",
      "in": "query",
      "type": "integer",
      "default": 20,
      "description": "Maximum number of items to return"
    },
    "offset": {
      "name": "offset",
      "in": "query",
      "type": "integer",
      "default": 0,
      "description": "Number of items to skip (for pagination)"
    },
    "sort_desc": {
      "name": "sort_desc",
      "in": "query",
      "type": "boolean",
      "default": true,
      "description": "Sort results descending by creation time"
    }
  },
  "responses": {
    "BadRequest": {
      "description": "Bad Request — invalid or missing parameters",
      "schema": { "$ref": "#/definitions/Error" }
    },
    "Unauthorized": {
      "description": "Unauthorized — missing or invalid Bearer token",
      "schema": { "$ref": "#/definitions/Error" }
    },
    "NotFound": {
      "description": "Resource not found",
      "schema": { "$ref": "#/definitions/Error" }
    },
    "Conflict": {
      "description": "Conflict — resource is in use or already exists",
      "schema": { "$ref": "#/definitions/Error" }
    }
  },
  "definitions": {
    "Error": {
      "type": "object",
      "properties": {
        "status": { "type": "integer", "example": 404 },
        "message": { "type": "string", "example": "Volume not found" }
      }
    },
    "VolumeCreateAndAttach": {
      "type": "object",
      "required": ["volume_name", "volume_size", "bootable", "billing_unit"],
      "properties": {
        "volume_name": {
          "type": "string",
          "description": "Alphanumeric volume name",
          "example": "my-data-volume"
        },
        "volume_size": {
          "type": "integer",
          "description": "Volume size in GB",
          "example": 50
        },
        "bootable": {
          "type": "boolean",
          "description": "Whether this is a boot (OS) volume",
          "example": false
        },
        "billing_unit": {
          "type": "string",
          "enum": ["MRC", "HRC"],
          "description": "Billing unit — MRC (monthly) or HRC (hourly)",
          "example": "MRC"
        },
        "volume_type": {
          "type": "string",
          "description": "Volume type name",
          "example": "ssd"
        },
        "volume_type_id": {
          "type": "string",
          "description": "Volume type UUID"
        },
        "enable_backup": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic backups"
        },
        "multiattach": {
          "type": "boolean",
          "default": false,
          "description": "Allow attaching to multiple compute instances simultaneously"
        },
        "compute_id": {
          "type": "string",
          "description": "Compute UUID to attach the volume to after creation"
        },
        "volume_attachment_device_name": {
          "type": "string",
          "description": "Device path on the compute instance",
          "example": "/dev/vdb"
        },
        "snapshot_id": {
          "type": "string",
          "description": "Create volume from this snapshot UUID"
        },
        "products": {
          "type": "object",
          "description": "Billing product mapping",
          "example": { "volume": { "id": "01t1m000003vqOEAAY" } }
        }
      }
    },
    "VolumeExtend": {
      "type": "object",
      "required": ["volume_size"],
      "properties": {
        "volume_size": {
          "type": "integer",
          "description": "New size in GB — must be greater than current size",
          "example": 100
        },
        "billing_unit": {
          "type": "string",
          "enum": ["MRC", "HRC"],
          "description": "Billing unit",
          "example": "MRC"
        }
      }
    },
    "VolumeAttach": {
      "type": "object",
      "required": ["compute_id"],
      "properties": {
        "compute_id": {
          "type": "string",
          "description": "UUID of the compute instance to attach the volume to",
          "example": "abc123-compute-uuid"
        },
        "volume_attachment_device_name": {
          "type": "string",
          "description": "Device path on the compute instance",
          "example": "/dev/vdb"
        }
      }
    },
    "VolumeDetach": {
      "type": "object",
      "required": ["compute_id"],
      "properties": {
        "compute_id": {
          "type": "string",
          "description": "UUID of the compute instance to detach from",
          "example": "abc123-compute-uuid"
        }
      }
    },
    "VolumeResponse": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "readOnly": true },
        "uuid": { "type": "string", "readOnly": true },
        "name": { "type": "string" },
        "size": { "type": "integer", "description": "Volume size in GB" },
        "bootable": { "type": "boolean" },
        "multiattach": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["Creating", "Created", "Extending", "Attaching", "Detaching", "Deleting", "Error"]
        },
        "volume_type": { "type": "string" },
        "volume_type_id": { "type": "string" },
        "availability_zone": { "type": "string" },
        "enable_backup": { "type": "boolean" },
        "project_id": { "type": "integer" },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/definitions/AttachedDevice" },
          "readOnly": true
        },
        "labels": {
          "type": "array",
          "items": { "$ref": "#/definitions/LabelEntry" }
        }
      }
    },
    "PaginatedVolumes": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": { "$ref": "#/definitions/VolumeResponse" }
        },
        "total": { "type": "integer" },
        "limit": { "type": "integer" },
        "offset": { "type": "integer" }
      }
    },
    "SnapshotCreate": {
      "type": "object",
      "required": ["snapshot_name"],
      "properties": {
        "snapshot_name": {
          "type": "string",
          "description": "Name for the snapshot",
          "example": "my-snapshot"
        },
        "billing_unit": {
          "type": "string",
          "enum": ["MRC", "HRC"],
          "default": "MRC",
          "description": "Billing unit"
        },
        "products": {
          "type": "object",
          "description": "Billing product mapping",
          "example": { "volume_snapshot": { "id": "01t1m000003vqOEAAY" } }
        }
      }
    },
    "SnapshotResponse": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "readOnly": true },
        "uuid": { "type": "string", "readOnly": true },
        "name": { "type": "string" },
        "size": { "type": "integer", "description": "Snapshot size in GB" },
        "status": {
          "type": "string",
          "enum": ["Creating", "Created", "Deleting", "Error"]
        },
        "volume_id": { "type": "integer" },
        "volume_uuid": { "type": "string" },
        "project_id": { "type": "integer" },
        "availability_zone": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "labels": {
          "type": "array",
          "items": { "$ref": "#/definitions/LabelEntry" }
        }
      }
    },
    "PaginatedSnapshots": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": { "$ref": "#/definitions/SnapshotResponse" }
        },
        "total": { "type": "integer" },
        "limit": { "type": "integer" },
        "offset": { "type": "integer" }
      }
    },
    "AttachedDevice": {
      "type": "object",
      "properties": {
        "compute_id": { "type": "string" },
        "compute_name": { "type": "string" },
        "device": { "type": "string", "example": "/dev/vdb" },
        "attachment_id": { "type": "string" },
        "attached_at": { "type": "string", "format": "date-time" }
      }
    },
    "VolumeType": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "readOnly": true },
        "uuid": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "is_public": { "type": "boolean" }
      }
    },
    "FilesystemFormat": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "readOnly": true },
        "name": { "type": "string", "example": "ext4" },
        "description": { "type": "string" }
      }
    },
    "LabelEntry": {
      "type": "object",
      "properties": {
        "key": { "type": "string", "example": "env" },
        "value": { "type": "string", "example": "production" }
      }
    },
    "LabelPatch": {
      "type": "object",
      "required": ["resource_id", "labels"],
      "properties": {
        "resource_id": {
          "type": "string",
          "description": "UUID of the volume or snapshot to label"
        },
        "labels": {
          "type": "array",
          "items": { "$ref": "#/definitions/LabelEntry" },
          "description": "Labels to add or update"
        }
      }
    }
  }
}
